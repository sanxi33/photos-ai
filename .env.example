# Photos AI runtime config
# 复制为 .env 后按需修改：cp .env.example .env

# 你的本地 OpenAI 兼容接口（完整地址）
PHOTOS_AI_API_URL=http://127.0.0.1:8001/v1/chat/completions

# 接口密钥（本地服务可自定义）
PHOTOS_AI_API_KEY=ggg123

# 默认模型（按你的要求固定推荐）
PHOTOS_AI_MODEL=Qwen3-VL-8B-NSFW-Caption-V4.5-mxfp4

# 空闲检测：空闲多少秒后开始处理（默认 10 分钟）
PHOTOS_AI_IDLE_THRESHOLD_SECONDS=600

# 检查空闲状态的轮询间隔（秒）
PHOTOS_AI_POLL_INTERVAL_SECONDS=10

# 状态文件（相对项目根目录）
PHOTOS_AI_STATE_FILE=state.json

# 生成长度控制
PHOTOS_AI_MAX_TOKENS=768
PHOTOS_AI_RETRY_MAX_TOKENS=512
